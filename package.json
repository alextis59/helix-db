{
  "name": "@helix-db-internal/workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Private HelixDB development workspace; no database or public package functionality",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@11.18.0+sha512.4faecce0be70366d1c67b1012c4adc1246354a6cc45bf589f92003073b05518d547403df1475c542d67a4845e22b4fafcd7cac0af02c7a96cc6814f09eb003fb",
  "engines": {
    "node": ">=22.12.0 <23 || >=24.11.0 <25",
    "npm": "11.18.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.12.0 <23 || >=24.11.0 <25",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.18.0",
      "onFail": "error"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "allowScripts": {
    "fsevents": false
  },
  "scripts": {
    "artifacts:browser-report": "node tests/toolchain/collect-retained-artifacts.mjs browser-reports",
    "artifacts:golden-formats": "node tests/toolchain/collect-retained-artifacts.mjs golden-formats hdoc-v1",
    "artifacts:coverage-replay": "node tests/toolchain/collect-retained-artifacts.mjs test-replays coverage",
    "artifacts:policy": "node tests/toolchain/check-retained-artifacts.mjs policy",
    "artifacts:test": "node tests/toolchain/test-artifact-retention-contract.mjs",
    "artifacts:test-replay": "node tests/toolchain/collect-retained-artifacts.mjs test-replays semantic",
    "benchmark:baseline": "node benchmarks/run-baseline.mjs",
    "benchmark:check": "node benchmarks/check-benchmark-artifacts.mjs report",
    "benchmark:hdoc": "node benchmarks/run-hdoc.mjs",
    "benchmark:hdoc:check": "node benchmarks/check-hdoc.mjs report",
    "benchmark:hdoc:decisions": "node benchmarks/check-hdoc-decisions.mjs",
    "benchmark:hdoc:decisions:test": "node tests/toolchain/test-hdoc-decisions-contract.mjs",
    "benchmark:hdoc:policy": "node benchmarks/check-hdoc.mjs policy",
    "benchmark:hdoc:test": "node tests/toolchain/test-hdoc-benchmark-contract.mjs",
    "benchmark:schemas": "node benchmarks/check-benchmark-artifacts.mjs schemas",
    "benchmark:test": "node tests/toolchain/test-benchmark-contract.mjs",
    "bootstrap:check": "node tests/toolchain/check-bootstrap.mjs contract",
    "bootstrap:preflight": "node tests/toolchain/check-bootstrap.mjs preflight",
    "bootstrap:test": "node tests/toolchain/test-bootstrap-contract.mjs",
    "browser:build": "node tests/toolchain/build-browser-smoke.mjs",
    "browser:install": "playwright install chromium firefox webkit",
    "browser:serve": "vite preview",
    "browser:smoke": "node tests/toolchain/run-browser-smoke.mjs all",
    "ci:browser-smoke": "node tests/toolchain/run-browser-smoke.mjs",
    "ci:check": "node tests/toolchain/check-ci-matrix.mjs",
    "coverage:check": "node tests/toolchain/check-rust-coverage.mjs run",
    "coverage:policy": "node tests/toolchain/check-rust-coverage.mjs policy",
    "core:boundary:check": "node tests/toolchain/check-deterministic-core.mjs",
    "core:boundary:test": "node tests/toolchain/test-deterministic-core-contract.mjs",
    "dependencies:check": "node tests/toolchain/check-dependency-reports.mjs offline",
    "dependencies:licenses": "node tests/toolchain/check-dependency-reports.mjs licenses",
    "dependencies:report": "node tests/toolchain/check-dependency-reports.mjs live",
    "examples:browser": "node tests/toolchain/check-examples.mjs browser",
    "examples:check": "node tests/toolchain/check-examples.mjs all",
    "examples:native": "node tests/toolchain/check-examples.mjs native",
    "examples:policy": "node tests/toolchain/check-examples.mjs policy",
    "examples:test": "node tests/toolchain/test-examples-contract.mjs",
    "fixtures:check": "node fixtures/generation/check.mjs",
    "fixtures:generate": "node fixtures/generation/generate.mjs --write",
    "fuzz:policy": "node tests/toolchain/check-hdoc-fuzz.mjs policy",
    "fuzz:smoke": "node tests/toolchain/check-hdoc-fuzz.mjs smoke",
    "fuzz:test": "node tests/toolchain/test-hdoc-fuzz-contract.mjs",
    "host:capabilities:check": "node tests/toolchain/check-host-capabilities.mjs",
    "host:capabilities:test": "node tests/toolchain/test-host-capabilities-contract.mjs",
    "policy:javascript": "biome check --error-on-warnings .",
    "policy:dependencies": "node tests/toolchain/check-dependency-policy.mjs",
    "rust:audit:install": "node tests/toolchain/install-cargo-audit.mjs",
    "rust:audit:test": "node tests/toolchain/test-cargo-audit-contract.mjs",
    "rust:dependencies:test": "node tests/toolchain/test-rust-dependency-contract.mjs",
    "test": "node tests/run-suite.mjs all",
    "test:all": "node tests/run-suite.mjs all",
    "test:benchmark": "node tests/run-suite.mjs benchmark",
    "test:browser": "node tests/run-suite.mjs browser",
    "test:commands": "node tests/toolchain/check-test-command-surface.mjs",
    "test:conformance": "node tests/run-suite.mjs conformance",
    "test:crash": "node tests/run-suite.mjs crash",
    "test:distributed": "node tests/run-suite.mjs distributed",
    "test:fuzz": "node tests/run-suite.mjs fuzz",
    "test:integration": "node tests/run-suite.mjs integration",
    "test:unit": "node tests/run-suite.mjs unit",
    "toolchain:types": "tsc --build --pretty false && tsc --project tsconfig.tools.json --pretty false",
    "toolchain:test-runner": "vitest run --passWithNoTests",
    "toolchain:browser-harness": "playwright test --list",
    "toolchain:browser-profile": "node tests/toolchain/check-browser-profile.mjs",
    "wasm:install-validator": "node tests/toolchain/install-wasm-tools.mjs",
    "wasm:abi:check": "node tests/toolchain/check-wasm-abi.mjs",
    "wasm:abi:test": "node tests/toolchain/test-wasm-abi-contract.mjs",
    "wasm:validate": "node tests/toolchain/check-deterministic-core.mjs && node tests/toolchain/check-wasm-abi.mjs && node tests/toolchain/check-host-capabilities.mjs && node tests/toolchain/check-wasm-artifacts.mjs all",
    "wgsl:check": "node tests/toolchain/check-wgsl-fixtures.mjs manifest",
    "wgsl:validate": "node tests/toolchain/check-wgsl-fixtures.mjs chromium"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
