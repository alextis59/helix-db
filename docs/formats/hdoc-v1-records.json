  ],
  "deferrals": [
    {
      "owner": "P03-008-P03-009",
      "scope": "production-encoder-and-bounded-validating-decoder"
    },
    {
      "owner": "P03-013",
      "scope": "feature-gated-collection-path-dictionary-ids-and-name-elision-profile"
    },
    {
      "owner": "P03-015",
      "scope": "extension-and-reader-writer-feature-migration-matrix"
    },
