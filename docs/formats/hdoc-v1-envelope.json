  "canonical_rules": [
    {
      "id": "header-size",
      "expression": "header_bytes = 64 + section_count * 32"
    },
    {
      "id": "directory-position",
      "expression": "directory_offset = 64"
    },
    {
      "id": "section-placement",
      "expression": "stored section_offset[i] = align8(previous stored section end), first previous end = header_bytes"
    },
    {
      "id": "logical-section-placement",
      "expression": "logical_section_offset[i] = align8(previous logical section end using logical_length), first previous end = header_bytes"
    },
    {
      "id": "footer-position",
      "expression": "footer_offset = align8(last_section_end)"
    },
    {
      "id": "stored-length",
      "expression": "total_length = footer_offset + 64 = exact supplied HDoc slice length"
    },
    {
      "id": "length-bounds",
      "expression": "256 <= total_length <= canonical_length <= 16777216"
    },
    {
      "id": "uncompressed-length",
      "expression": "without compressed sections, total_length = canonical_length"
    },
    {
      "id": "canonical-logical-length",
      "expression": "canonical_length = align8(last logical section end) + 64"
    },
    {
      "id": "internal-offset-space",
      "expression": "all P03-004/P03-005 absolute offsets address canonical logical coordinates; stored and logical coordinates coincide only when no prior stored section shrank"
    },
    {
      "id": "compressed-document-selection",
      "expression": "profile 1/1 compresses every and only beneficial base section and is emitted only when total_length < canonical_length"
    },
    {
      "id": "footer-copies",
      "expression": "footer length/count copies equal header total_length, canonical_length, and field_count"
    },
    {
      "id": "checksum-coverage",
      "expression": "CRC32C covers bytes [0,total_length), treating bytes [32,36) as zero"
    },
    {
      "id": "field-count",
      "expression": "field_count is the total recursive object-field entry count and equals field_table item_count"
    },
    {
      "id": "padding",
      "expression": "all canonical gaps are the minimum align8 padding and contain only zero bytes"
    },
    {
      "id": "directory-order",
      "expression": "directory entries are unique and ordered by section kind in canonical section order"
    }
  ]
}
