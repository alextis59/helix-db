  "claim_boundary": "These examples prove native linking and browser Wasm bundling only; they expose no document, query, storage, durability, GPU, network, compatibility, security, or release functionality.",
  "native": {
    "id": "native-toolchain",
    "state": "active-boundary-example",
    "manifest": "examples/native-toolchain/Cargo.toml",
