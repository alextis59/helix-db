{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helix-db:schema:semantic-fixture:1",
  "title": "HelixDB language-neutral semantic fixture v1",
  "description": "One deterministic semantic scenario. Constraints that require cross-field value semantics are defined by docs/quality/semantic-fixture-format.md and enforced by semantic corpus tooling.",
  "type": "object",
  "required": [
    "fixture_schema",
    "id",
    "title",
    "requirements",
    "plan_items",
    "profiles",
    "tags",
    "initial_state",
    "steps"
  ],
  "properties": {
    "fixture_schema": {
      "const": "helix.semantic-fixture/1"
    },
    "id": {
      "$ref": "#/$defs/stable_id"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(INV|PLAT|CORE|DATA|QUERY|STORE|GPU|DIST|CACHE|SYNC|SEC|OPS|QUAL|COMPAT)-[0-9]{3}$"
      }
    },
    "plan_items": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(P[0-9]{2}-[0-9]{3}|G[0-9]{2}|X-[0-9]{3})$"
      }
    },
    "profiles": {
      "$ref": "#/$defs/profiles"
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stable_id"
      }
    },
    "initial_state": {
      "$ref": "#/$defs/initial_state"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "canonical_signed_integer": {
      "type": "string",
      "pattern": "^(?:0|-[1-9][0-9]*|[1-9][0-9]*)$"
    },
    "canonical_nonnegative_integer": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)$"
    },
    "safe_json_integer": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "safe_nonnegative_integer": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "profiles": {
      "type": "object",
      "required": [
        "semantics",
        "limits",
        "collation",
        "errors",
        "default_order"
      ],
      "properties": {
        "semantics": {
          "const": "helix-native-v1"
        },
        "limits": {
          "const": "limits-v1"
        },
        "collation": {
          "const": "binary_utf8_v1"
        },
        "errors": {
          "const": "errors-v1"
        },
        "default_order": {
          "const": "default_order_v1"
        }
      },
      "additionalProperties": false
    },
    "initial_state": {
      "type": "object",
      "required": ["collections"],
      "properties": {
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        },
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/collection_state"
          }
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "wall_time_reads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timestamp_value"
          }
        },
        "expiry_time_reads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/timestamp_value"
          }
        },
        "monotonic_ticks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonical_nonnegative_integer"
          }
        },
        "transaction_sequence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonical_nonnegative_integer"
          }
        },
        "random_hex": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?:[0-9a-f]{2})*$"
          }
        },
        "features": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/stable_id"
          },
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "quotas": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/stable_id"
          },
          "additionalProperties": {
            "$ref": "#/$defs/safe_json_integer"
          }
        }
      },
      "additionalProperties": false
    },
    "collection_state": {
      "type": "object",
      "required": ["name", "document_order", "documents"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[^\\u0000]+$"
        },
        "document_order": {
          "const": "default_order_v1"
        },
        "documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/object_value"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_node"
          }
        },
        "options": {
          "$ref": "#/$defs/command_node"
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["id", "action", "expect"],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "expect": {
          "$ref": "#/$defs/expectation"
        }
      },
      "additionalProperties": false
    },
    "action": {
      "oneOf": [
        {
          "$ref": "#/$defs/command_action"
        },
        {
          "$ref": "#/$defs/raw_input_action"
        },
        {
          "$ref": "#/$defs/value_operation_action"
        }
      ]
    },
    "command_action": {
      "type": "object",
      "required": ["kind", "command"],
      "properties": {
        "kind": {
          "const": "command"
        },
        "command": {
          "$ref": "#/$defs/command_node"
        }
      },
      "additionalProperties": false
    },
    "raw_input_action": {
      "type": "object",
      "required": ["kind", "target", "encoding", "compression", "bytes_hex"],
      "properties": {
        "kind": {
          "const": "raw_input"
        },
        "target": {
          "enum": ["command", "document", "value", "protocol_frame"]
        },
        "encoding": {
          "enum": ["json", "cbor", "hdoc", "native_frame"]
        },
        "compression": {
          "enum": ["identity", "gzip", "zstd"]
        },
        "bytes_hex": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{2})*$"
        }
      },
      "additionalProperties": false
    },
    "value_operation_action": {
      "type": "object",
      "required": ["kind", "operation", "arguments"],
      "properties": {
        "kind": {
          "const": "value_operation"
        },
        "operation": {
          "$ref": "#/$defs/stable_id"
        },
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observable_value"
          }
        },
        "options": {
          "$ref": "#/$defs/command_node"
        }
      },
      "additionalProperties": false
    },
    "command_node": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/safe_json_integer"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_node"
          }
        },
        {
          "$ref": "#/$defs/command_literal"
        },
        {
          "type": "object",
          "not": {
            "required": ["$value"]
          },
          "propertyNames": {
            "type": "string",
            "maxLength": 1024
          },
          "additionalProperties": {
            "$ref": "#/$defs/command_node"
          }
        }
      ]
    },
    "command_literal": {
      "type": "object",
      "required": ["$value"],
      "properties": {
        "$value": {
          "$ref": "#/$defs/logical_value"
        }
      },
      "additionalProperties": false
    },
    "expectation": {
      "oneOf": [
        {
          "$ref": "#/$defs/success_expectation"
        },
        {
          "$ref": "#/$defs/error_expectation"
        }
      ]
    },
    "success_expectation": {
      "type": "object",
      "required": ["kind", "value", "order", "state"],
      "properties": {
        "kind": {
          "const": "success"
        },
        "value": {
          "$ref": "#/$defs/observable_value"
        },
        "order": {
          "$ref": "#/$defs/order_expectation"
        },
        "state": {
          "$ref": "#/$defs/state_expectation"
        }
      },
      "additionalProperties": false
    },
    "error_expectation": {
      "type": "object",
      "required": [
        "kind",
        "category",
        "code",
        "phase",
        "outcome",
        "retry",
        "details_match",
        "order",
        "state"
      ],
      "properties": {
        "kind": {
          "const": "error"
        },
        "category": {
          "enum": [
            "parse",
            "validation",
            "type",
            "conflict",
            "uniqueness",
            "authorization",
            "capability",
            "quota",
            "deadline",
            "durability",
            "internal"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "phase": {
          "enum": [
            "wire",
            "decode",
            "validate",
            "authorize",
            "admit",
            "snapshot",
            "plan",
            "execute",
            "commit",
            "acknowledge",
            "cursor",
            "backup",
            "restore",
            "recover",
            "internal"
          ]
        },
        "outcome": {
          "enum": ["not_applicable", "not_committed", "committed", "unknown"]
        },
        "retry": {
          "$ref": "#/$defs/retry_expectation"
        },
        "details_match": {
          "enum": ["exact", "subset", "absent"]
        },
        "details": {
          "$ref": "#/$defs/json_object"
        },
        "causes": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/cause_expectation"
          }
        },
        "order": {
          "$ref": "#/$defs/order_expectation"
        },
        "state": {
          "$ref": "#/$defs/state_expectation"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "details_match": {
                "const": "absent"
              }
            },
            "required": ["details_match"]
          },
          "then": {
            "not": {
              "required": ["details"]
            }
          },
          "else": {
            "required": ["details"]
          }
        }
      ],
      "additionalProperties": false
    },
    "retry_expectation": {
      "type": "object",
      "required": ["retryable", "scope", "token"],
      "properties": {
        "retryable": {
          "type": "boolean"
        },
        "scope": {
          "enum": [
            "never",
            "same_request",
            "same_idempotency_key",
            "new_snapshot",
            "after_delay",
            "after_capability_change",
            "after_operator_action"
          ]
        },
        "min_delay_ms": {
          "$ref": "#/$defs/safe_nonnegative_integer"
        },
        "max_attempts_hint": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "token": {
          "enum": ["absent", "present", "ignore"]
        }
      },
      "additionalProperties": false
    },
    "cause_expectation": {
      "type": "object",
      "required": ["category", "code", "phase", "details_match"],
      "properties": {
        "category": {
          "enum": [
            "parse",
            "validation",
            "type",
            "conflict",
            "uniqueness",
            "authorization",
            "capability",
            "quota",
            "deadline",
            "durability",
            "internal"
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "phase": {
          "enum": [
            "wire",
            "decode",
            "validate",
            "authorize",
            "admit",
            "snapshot",
            "plan",
            "execute",
            "commit",
            "acknowledge",
            "cursor",
            "backup",
            "restore",
            "recover",
            "internal"
          ]
        },
        "details_match": {
          "enum": ["exact", "subset", "absent"]
        },
        "details": {
          "$ref": "#/$defs/json_object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "details_match": {
                "const": "absent"
              }
            },
            "required": ["details_match"]
          },
          "then": {
            "not": {
              "required": ["details"]
            }
          },
          "else": {
            "required": ["details"]
          }
        }
      ],
      "additionalProperties": false
    },
    "order_expectation": {
      "type": "object",
      "required": ["mode", "basis", "row_count", "keys"],
      "properties": {
        "mode": {
          "enum": ["exact", "set", "not_applicable"]
        },
        "basis": {
          "enum": [
            "default_order_v1",
            "explicit_sort",
            "vector_rank",
            "pipeline_ordinal",
            "input_order",
            "singleton",
            "set_semantics",
            "not_applicable"
          ]
        },
        "row_count": {
          "$ref": "#/$defs/safe_nonnegative_integer"
        },
        "keys": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/order_key"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "set"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "basis": {
                "const": "set_semantics"
              },
              "keys": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "not_applicable"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "basis": {
                "const": "not_applicable"
              },
              "keys": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "exact"
              }
            },
            "required": ["mode"]
          },
          "then": {
            "properties": {
              "basis": {
                "not": {
                  "enum": ["set_semantics", "not_applicable"]
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "order_key": {
      "type": "object",
      "required": ["components"],
      "properties": {
        "components": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/order_component"
          }
        }
      },
      "additionalProperties": false
    },
    "order_component": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "direction", "value"],
          "properties": {
            "kind": {
              "const": "value"
            },
            "direction": {
              "enum": ["asc", "desc"]
            },
            "value": {
              "$ref": "#/$defs/observable_value"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "index"
            },
            "value": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "branch"
            },
            "value": {
              "$ref": "#/$defs/stable_id"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "singleton"
            },
            "value": {
              "$ref": "#/$defs/stable_id"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "state_expectation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": {
              "const": "unchanged"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode", "scope", "collections"],
          "properties": {
            "mode": {
              "const": "exact"
            },
            "scope": {
              "enum": ["all", "listed"]
            },
            "collections": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/collection_state"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": {
              "const": "unknown"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": {
              "const": "not_observed"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "json_data": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/safe_json_integer"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_data"
          }
        },
        {
          "$ref": "#/$defs/json_object"
        }
      ]
    },
    "json_object": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/json_data"
      }
    },
    "observable_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/logical_value"
        },
        {
          "$ref": "#/$defs/missing_value"
        }
      ]
    },
    "logical_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/null_value"
        },
        {
          "$ref": "#/$defs/bool_value"
        },
        {
          "$ref": "#/$defs/int32_value"
        },
        {
          "$ref": "#/$defs/int64_value"
        },
        {
          "$ref": "#/$defs/float64_value"
        },
        {
          "$ref": "#/$defs/decimal128_value"
        },
        {
          "$ref": "#/$defs/string_value"
        },
        {
          "$ref": "#/$defs/binary_value"
        },
        {
          "$ref": "#/$defs/object_value"
        },
        {
          "$ref": "#/$defs/array_value"
        },
        {
          "$ref": "#/$defs/timestamp_value"
        },
        {
          "$ref": "#/$defs/date_value"
        },
        {
          "$ref": "#/$defs/uuid_value"
        },
        {
          "$ref": "#/$defs/object_id_value"
        },
        {
          "$ref": "#/$defs/vector_value"
        }
      ]
    },
    "missing_value": {
      "type": "object",
      "required": ["t"],
      "properties": {
        "t": {
          "const": "missing"
        }
      },
      "additionalProperties": false
    },
    "null_value": {
      "type": "object",
      "required": ["t"],
      "properties": {
        "t": {
          "const": "null"
        }
      },
      "additionalProperties": false
    },
    "bool_value": {
      "type": "object",
      "required": ["t", "value"],
      "properties": {
        "t": {
          "const": "bool"
        },
        "value": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "int32_value": {
      "type": "object",
      "required": ["t", "value"],
      "properties": {
        "t": {
          "const": "int32"
        },
        "value": {
          "$ref": "#/$defs/canonical_signed_integer"
        }
      },
      "additionalProperties": false
    },
    "int64_value": {
      "type": "object",
      "required": ["t", "value"],
      "properties": {
        "t": {
          "const": "int64"
        },
        "value": {
          "$ref": "#/$defs/canonical_signed_integer"
        }
      },
      "additionalProperties": false
    },
    "float64_value": {
      "type": "object",
      "required": ["t", "bits"],
      "properties": {
        "t": {
          "const": "float64"
        },
        "bits": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        }
      },
      "additionalProperties": false
    },
    "decimal128_value": {
      "oneOf": [
        {
          "type": "object",
          "required": ["t", "class", "sign", "coefficient", "exponent"],
          "properties": {
            "t": {
              "const": "decimal128"
            },
            "class": {
              "const": "finite"
            },
            "sign": {
              "enum": ["positive", "negative"]
            },
            "coefficient": {
              "const": "0"
            },
            "exponent": {
              "const": "0"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["t", "class", "sign", "coefficient", "exponent"],
          "properties": {
            "t": {
              "const": "decimal128"
            },
            "class": {
              "const": "finite"
            },
            "sign": {
              "enum": ["positive", "negative"]
            },
            "coefficient": {
              "type": "string",
              "pattern": "^[1-9](?:[0-9]{0,32}[1-9])?$"
            },
            "exponent": {
              "$ref": "#/$defs/canonical_signed_integer"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["t", "class", "sign"],
