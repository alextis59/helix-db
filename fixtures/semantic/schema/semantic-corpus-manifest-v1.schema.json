{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helix-db:schema:semantic-corpus-manifest:1",
  "title": "HelixDB semantic corpus manifest v1",
  "description": "Deterministic inventory, integrity, and requirement coverage for semantic-fixture/1 files.",
  "type": "object",
  "required": [
    "manifest_schema",
    "fixture_schema",
    "semantic_profile",
    "hash_profile",
    "generated_by",
    "counts",
    "coverage",
    "fixtures"
  ],
  "properties": {
    "manifest_schema": {
      "const": "helix.semantic-corpus/1"
    },
    "fixture_schema": {
      "const": "helix.semantic-fixture/1"
    },
    "semantic_profile": {
      "const": "helix-native-v1"
    },
    "hash_profile": {
      "const": "sha256+jcs-rfc8785"
    },
    "generated_by": {
      "type": "object",
      "required": ["tool", "version"],
      "properties": {
        "tool": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){0,2}(?:-[0-9A-Za-z.-]+)?$"
        }
      },
      "additionalProperties": false
    },
    "counts": {
      "type": "object",
      "required": ["fixtures", "steps", "successes", "errors"],
      "properties": {
        "fixtures": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "steps": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "successes": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "errors": {
          "$ref": "#/$defs/nonnegative_integer"
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^(INV|PLAT|CORE|DATA|QUERY|STORE|GPU|DIST|CACHE|SYNC|SEC|OPS|QUAL|COMPAT)-[0-9]{3}$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "$ref": "#/$defs/stable_id"
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fixture_entry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stable_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "nonnegative_integer": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "fixture_entry": {
      "type": "object",
      "required": [
        "id",
        "path",
        "bytes",
        "source_sha256",
        "canonical_sha256",
        "requirements",
        "tags",
        "steps"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "path": {
          "type": "string",
          "pattern": "^fixtures/semantic/cases/[a-z0-9][a-z0-9/._-]*\\.json$"
        },
        "bytes": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "canonical_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(INV|PLAT|CORE|DATA|QUERY|STORE|GPU|DIST|CACHE|SYNC|SEC|OPS|QUAL|COMPAT)-[0-9]{3}$"
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        },
        "steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        }
      },
      "additionalProperties": false
    }
  }
}
