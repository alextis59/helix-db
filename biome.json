{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 2097152,
    "includes": [
      "*.json",
      "*.ts",
      ".github/ci/*.json",
      "benchmarks/**/*.json",
      "benchmarks/**/*.mjs",
      "compatibility/**/*.mjs",
      "differential/**/*.{mjs,js}",
      "docs/development/*.json",
      "fixtures/generation/**/*.json",
      "fixtures/**/*.mjs",
      "packages/**/*.ts",
      "reference/**/*.mjs",
      "shaders/**/*.json",
      "tests/**/*.mjs",
      "tests/**/*.ts",
      "tests/toolchain/*.json",
      "tests/toolchain/schema/*.json",
      "!package-lock.json",
      "!!evidence",
      "!!target",
      "!!node_modules",
      "!!dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "useNodejsImportProtocol": "error"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
