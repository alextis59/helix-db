{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.helix-db.invalid/benchmark/hdoc-decisions-v1.schema.json",
  "title": "HelixDB HDoc experiment decisions version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "plan_item",
    "recorded_on",
    "inputs",
    "experiments",
    "claim_boundary",
    "verdict"
  ],
  "properties": {
    "schema": { "const": "helix.hdoc-experiment-decisions/1" },
    "plan_item": { "const": "P03-021" },
    "recorded_on": { "const": "2026-07-12" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw", "summary", "source_commit"],
      "properties": {
        "raw": { "$ref": "#/$defs/fileIdentity" },
        "summary": { "$ref": "#/$defs/fileIdentity" },
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "experiments": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [{ "$ref": "#/$defs/experiment1" }, { "$ref": "#/$defs/experiment2" }],
      "items": false
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "performance_slo",
        "cross_machine_comparison",
        "dictionary_reference_profile_implemented",
        "storage_or_query_performance_claim"
      ],
      "properties": {
        "performance_slo": { "type": "null" },
        "cross_machine_comparison": { "const": false },
        "dictionary_reference_profile_implemented": { "const": false },
        "storage_or_query_performance_claim": { "const": false }
      }
    },
    "verdict": { "const": "pass" }
  },
  "$defs": {
    "fileIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 256 },
        "bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "experiment1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "hypothesis", "verdict", "observations", "decision"],
      "properties": {
        "id": { "const": "EXP-001" },
        "hypothesis": { "type": "string", "minLength": 20 },
        "verdict": { "const": "accepted-without-performance-slo" },
        "observations": { "$ref": "#/$defs/experiment1Observations" },
        "decision": { "$ref": "#/$defs/experiment1Decision" }
      }
    },
    "experiment1Observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "representative_shapes",
        "codec_lookup_operations",
        "measurement_samples",
        "timed_iterations",
        "semantic_and_corruption_gates",
        "cross_language_property_fuzz_browser_gates",
        "timing_threshold"
      ],
      "properties": {
        "representative_shapes": { "const": 5 },
        "codec_lookup_operations": { "const": 30 },
        "measurement_samples": { "const": 600 },
        "timed_iterations": { "const": 9600 },
        "semantic_and_corruption_gates": { "const": "pass" },
        "cross_language_property_fuzz_browser_gates": { "const": "pass" },
        "timing_threshold": { "type": "null" }
      }
    },
    "experiment1Decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_format",
        "selected_stored_profiles",
        "direct_field_lookup",
        "nested_path_lookup",
        "reason"
      ],
      "properties": {
        "selected_format": { "const": "helix.hdoc/1.0" },
        "selected_stored_profiles": {
          "type": "array",
          "prefixItems": [{ "const": "base" }, { "const": "canonical-compression-1" }],
          "items": false
        },
        "direct_field_lookup": {
          "const": "validated-name-and-object-table-binary-search"
        },
        "nested_path_lookup": { "const": "validated-bounded-borrowed-traversal" },
        "reason": { "type": "string", "minLength": 100, "maxLength": 1000 }
      }
    },
    "experiment2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "hypothesis", "verdict", "observations", "decision"],
      "properties": {
        "id": { "const": "EXP-002" },
        "hypothesis": { "type": "string", "minLength": 20 },
        "verdict": { "const": "partially-supported-shape-dependent" },
        "observations": { "$ref": "#/$defs/experiment2Observations" },
        "decision": { "$ref": "#/$defs/experiment2Decision" }
      }
    },
    "experiment2Observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modeled_documents_per_shape",
        "negative_shapes",
        "positive_shapes",
        "minimum_savings_basis_points",
        "maximum_savings_basis_points",
        "minimal_savings_bytes",
        "wide_128_savings_bytes"
      ],
      "properties": {
        "modeled_documents_per_shape": { "const": 10000 },
        "negative_shapes": { "const": 1 },
        "positive_shapes": { "const": 4 },
        "minimum_savings_basis_points": { "const": -3386 },
        "maximum_savings_basis_points": { "const": 8319 },
        "minimal_savings_bytes": { "const": -10160 },
        "wide_128_savings_bytes": { "const": 25383744 }
      }
    },
    "experiment2Decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retain_collection_path_dictionary",
        "use_for_derived_sidecars_and_metadata",
        "use_dictionary_references_in_hdoc_1_0",
        "authoritative_hdoc_remains_self_contained",
        "future_reference_profile",
        "future_prerequisites",
        "reason"
      ],
      "properties": {
        "retain_collection_path_dictionary": { "const": true },
        "use_for_derived_sidecars_and_metadata": { "const": true },
        "use_dictionary_references_in_hdoc_1_0": { "const": false },
        "authoritative_hdoc_remains_self_contained": { "const": true },
        "future_reference_profile": { "const": "conditional-new-negotiated-profile" },
        "future_prerequisites": {
          "type": "array",
          "prefixItems": [
            { "const": "real-workload-path-frequency-corpus" },
            { "const": "atomic-row-dictionary-version-pin-integration" },
            { "const": "read-write-amplification-and-recovery-benchmarks" },
            { "const": "cross-version-migration-and-rollback-proof" },
            { "const": "net-benefit-policy-that-allows-raw-name-fallback" }
          ],
          "items": false
        },
        "reason": { "type": "string", "minLength": 100, "maxLength": 1000 }
      }
    }
  }
}
