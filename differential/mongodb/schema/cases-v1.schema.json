{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:helix-db:schema:mongodb-differential-cases:1",
  "title": "HelixDB MongoDB differential cases v1",
  "type": "object",
  "required": [
    "cases_schema",
    "profile",
    "harness_version",
    "client",
    "upstream",
    "semantic_inputs",
    "sources",
    "datasets",
    "cases"
  ],
  "properties": {
    "cases_schema": { "const": "helix.mongodb-differential-cases/1" },
    "profile": { "const": "mongodb-6.0.5-initial-v1" },
    "harness_version": { "const": "1.0.1" },
    "client": {
      "type": "object",
      "required": ["product", "version"],
      "properties": {
        "product": { "const": "MongoDB Shell" },
        "version": { "const": "1.8.0" }
      },
      "additionalProperties": false
    },
    "upstream": {
      "type": "object",
      "required": [
        "product",
        "version",
        "git_version",
        "feature_compatibility_version",
        "max_wire_version",
        "image",
        "image_id"
      ],
      "properties": {
        "product": { "const": "MongoDB Community Server" },
        "version": { "const": "6.0.5" },
        "git_version": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "feature_compatibility_version": { "const": "6.0" },
        "max_wire_version": { "const": 17 },
        "image": { "type": "string", "pattern": "^mongo@sha256:[0-9a-f]{64}$" },
        "image_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "semantic_inputs": {
      "type": "object",
      "required": [
        "fixture_schema",
        "semantic_profile",
        "corpus_manifest_sha256",
        "oracle_report_sha256"
      ],
      "properties": {
        "fixture_schema": { "const": "helix.semantic-fixture/1" },
        "semantic_profile": { "const": "helix-native-v1" },
        "corpus_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "oracle_report_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^https://www\\.mongodb\\.com/docs/v6\\.0/" }
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "collection", "documents"],
        "properties": {
          "id": { "$ref": "#/$defs/stable_id" },
          "collection": { "$ref": "#/$defs/stable_id" },
          "documents": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "object" }
          }
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "family",
          "dataset",
          "requirements",
          "expected_relation",
          "translation",
          "comparison",
          "native",
          "mongo",
          "reason"
        ],
        "properties": {
          "id": { "$ref": "#/$defs/stable_id" },
          "family": { "$ref": "#/$defs/stable_id" },
          "dataset": { "$ref": "#/$defs/stable_id" },
          "requirements": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" }
          },
          "expected_relation": { "enum": ["exact", "different"] },
          "translation": { "enum": ["direct", "adapter_rewrite"] },
          "comparison": { "enum": ["ordered_ids", "ordered_rows"] },
          "native": { "$ref": "#/$defs/query" },
          "mongo": { "$ref": "#/$defs/query" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 1000 }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,126}[a-z0-9]$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "query": {
      "type": "object",
      "required": ["filter", "sort"],
      "properties": {
        "filter": { "type": "object" },
        "projection": { "type": "object" },
        "sort": { "type": "object", "minProperties": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
